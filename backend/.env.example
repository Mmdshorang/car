DB_NAME=car_system
DB_USER=postgres
DB_PASSWORD=your_password
DB_PORT=5435
JWT_SECRET=change_me

KAVENEGAR_API_KEY=replace_with_kavenegar_api_key
KAVENEGAR_TEMPLATE=verify
KAVENEGAR_TYPE=sms
KAVENEGAR_SENDER=

# Date reminder SMS
KAVENEGAR_DATE_REMINDER_TEMPLATE=date_reminder
KAVENEGAR_DATE_REMINDER_MODE=lookup
SMS_DATE_REMINDER_ENABLED_DEFAULT=false
SMS_DATE_REMINDER_DAYS_BEFORE=5
SMS_DATE_REMINDER_CRON=0 9 * * *
SMS_CRON_TZ=Asia/Tehran
